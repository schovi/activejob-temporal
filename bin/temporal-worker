#!/usr/bin/env ruby
# frozen_string_literal: true

require_relative "../lib/activejob/temporal"

begin
  require "temporalio/worker"
rescue LoadError => e
  warn("temporalio-worker gem is required to run this worker: #{e.message}")
  exit(1)
end

# Auto-detect and load Rails application if present
rails_root = ENV.fetch("RAILS_ROOT", ".")

if File.directory?(rails_root) && File.exist?(File.expand_path("config/application.rb", rails_root))
  # It's a Rails application - load the environment
  require File.expand_path("config/environment", rails_root)

  # Force eager loading of all job classes to prevent autoloading in workflows
  # Workflows must be deterministic and cannot use Thread::Mutex which autoloading triggers
  Rails.application.eager_load! if defined?(Rails) && (Rails.env.development? || Rails.env.test?)
elsif rails_root != "." && File.directory?(rails_root)
  # User specified a directory that exists but isn't a Rails app
  warn "Warning: #{rails_root} does not appear to be a Rails application"
  warn "Continuing without Rails environment. Job classes may not be available."
elsif rails_root != "."
  # User specified a path that doesn't exist
  warn "Error: Cannot find Rails application at: #{rails_root}"
  exit(1)
end
# If rails_root is "." and it's not a Rails app, just continue (gem development mode)

ActiveJob::Temporal.configure do |config|
  config.target = ENV.fetch("TEMPORAL_TARGET", config.target)
  config.namespace = ENV.fetch("TEMPORAL_NAMESPACE", config.namespace)
end

task_queue = ENV.fetch("AJ_TEMPORAL_WORKER_QUEUE", "default")
max_concurrent_activities = ENV.fetch("AJ_TEMPORAL_MAX_ACT", 100).to_i

client = ActiveJob::Temporal.client

worker = Temporalio::Worker.new(
  client: client,
  task_queue: task_queue,
  workflows: [ActiveJob::Temporal::Workflows::AjWorkflow],
  activities: [ActiveJob::Temporal::Activities::AjRunnerActivity],
  max_concurrent_activity_task_polls: max_concurrent_activities
)

ActiveJob::Temporal::Logger.log_event(
  "worker_started",
  task_queue: task_queue,
  max_concurrent_activities: max_concurrent_activities,
  namespace: ActiveJob::Temporal.config.namespace,
  target: ActiveJob::Temporal.config.target
)

begin
  Temporalio::Worker.run_all(
    worker,
    shutdown_signals: %w[SIGINT SIGTERM]
  )
rescue Interrupt
  # Temporal worker raises Interrupt on shutdown signals; swallow to allow clean exit.
ensure
  ActiveJob::Temporal::Logger.log_event(
    "worker_shutdown",
    task_queue: task_queue
  )
end
