# Docker Compose Environment Configuration
# Copy this file to .env and adjust values as needed

# Rails Configuration
RAILS_ENV=development

# Temporal Configuration
# The Temporal server address (when running via docker-compose, use 'temporal' as hostname)
TEMPORAL_TARGET=temporal:7233

# The Temporal namespace
TEMPORAL_NAMESPACE=default

# The queue name for ActiveJob workers
AJ_TEMPORAL_WORKER_QUEUE=default

# Rails Server Port
# Note: Port 3000 is exposed in docker-compose.yml, change there if needed
RAILS_PORT=3000

# Temporal UI Port
# Note: Port 8080 is exposed in docker-compose.yml, change there if needed
TEMPORAL_UI_PORT=8080

# PostgreSQL Configuration (for Temporal)
POSTGRES_USER=temporal
POSTGRES_PASSWORD=temporal
POSTGRES_DB=temporal

# Logging
RAILS_LOG_TO_STDOUT=1

# Optional: Add other Rails/gem configuration as needed
# For example, if your jobs use external APIs or services:
# API_KEY=your_api_key
# DATABASE_URL=sqlite3:///path/to/db.sqlite3
